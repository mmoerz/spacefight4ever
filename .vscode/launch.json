{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug selected package",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "cargo build package",
            "cargo": {
                "args": [
                    "run",
                    "--package",
                    "${input:mode == 'release' ? '--release' : ''"
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug integration tests for 'SF4E'",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "cargo test package",
            "cargo": {
                "args": [
                    "test",
                    "--package",
                    "${input:package}",
                    "--no-run"
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Release SF4E-bin",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "cargo build bin (release)",
            "cargo": {
                "args": [
                    "run",
                    "--package", "spacefight4ever-bin",
                    "--release"
                ]
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}