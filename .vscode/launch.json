{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug 'SF4E' bin",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "cargo build SF4E debug",
            "cargo": {
                "args": [
                    "run",
                    "--package",
                    "spacefight4ever-bin",
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug 'SF4E' integration tests",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "build SF4E integration tests",
            "program": "${workspaceFolder}/target/debug/deps/spacefight4ever_test-3b8beee0aa0b1a08",
            "args": ["--nocapture"],
            "cwd": "${workspaceFolder}",
            "env": {
                "LD_LIBRARY_PATH": "${workspaceFolder}/target/debug/deps"
            }
        },
        {
            "name": "Release SF4E-bin",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "cargo build bin (release)",
            "cargo": {
                "args": [
                    "run",
                    "--package", 
                    "spacefight4ever-bin",
                    "--release"
                ]
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}